# ── Required ────────────────────────────────────────────────────────────────
# Get a free key: https://brickset.com/tools/webservices/requestkey
BRICKSET_API_KEY=

# ── What to track ─────────────────────────────────────────────────────────────
# Comma-separated themes and subthemes to include.
THEMES=The Lord of the Rings,The Hobbit
SUBTHEMES=The Lord of the Rings,The Hobbit

# ── Resale / minifig values (opt-in, see README) ──
# Reads public, robots-permitted pages, rate-limited and identified.
# On Netlify, the scheduled refresh runs with a 30s timeout by default.
# Reading many minifig pages (4s delay each) may exceed that timeout.
# Leave disabled unless you enable the Background Function option.
ENABLE_PAGE_READER=false
PAGE_READER_DELAY_MS=4000
USER_AGENT=MiddleEarthBrickIndex/1.0 (Netlify; contact: you@example.com)

# Used-set resale provider. "null" = none (compliant default).
SET_VALUE_PROVIDER=null
